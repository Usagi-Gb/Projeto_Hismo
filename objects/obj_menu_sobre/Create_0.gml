// Textos de Controles e Mecânicas
titulo = "COMO JOGAR";

texto_controles = 
"W, A, S, D - Movimentar o personagem\n" +
"MOUSE ESQUERDO - Atirar\n" +
"Q - Executar um Dash (Esquiva rápida)\n" +
"ESPACO/ P - Voltar ao Menu Principal";

texto_mecanicas = 
"SISTEMA DE ONDAS: Sobreviva a hordas crescentes de inimigos.\n" +
"A cada 2 ondas concluidas, uma nova arma caira aleatoriamente no mapa.\n\n" +
"RITMO: Acerte os ataques no tempo da musica para ganhar bonus e ficar ciano!\n\n" +
"CURA: Inimigos derrotados tem 20% de chance de dropar um item de cura.\n\n" +
"MUSEU: Complete desafios secretos durante a partida (como matar\n" +
"uma quantidade exata de monstros) para desbloquear trofeus na galeria.";